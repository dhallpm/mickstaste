  "functions": {
    "api/micks-admin.js": {
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "vip.mickspicks.us"
        }
      ],
      "destination": "/vip",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "vip.mickspicks.us"
        }
      ],
      "destination": "/vip.html"
    },
    {
      "source": "/vip",
      "destination": "/vip.html"
    },
    {
      "source": "/api/vip-picks",
      "destination": "/api/todays-picks?vip=1"
    },
    {
      "source": "/api/website-feed",
      "destination": "/api/todays-picks"
    }
  ],
  "crons": [
    {
      "path": "/api/micks-admin",
      "schedule": "0 0 * * *"
    }
  ]
}
