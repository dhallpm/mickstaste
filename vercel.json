{
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/vip.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/vip",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/results.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/site-rules-override.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/micks-admin.js": { "maxDuration": 60 }
  },
  "redirects": [],
  "rewrites": [
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "vip.mickspicks.us" }
      ],
      "destination": "/vip.html"
    },
    {
      "source": "/vip",
      "destination": "/vip.html"
    },
    {
      "source": "/api/vip-picks",
      "destination": "/api/todays-picks?vip=1"
    },
    {
      "source": "/api/website-feed",
      "destination": "/api/todays-picks"
    }
  ],
  "crons": [
    { "path": "/api/micks-admin", "schedule": "0 0 * * *" }
  ]
}
