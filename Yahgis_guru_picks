  <script>
    /* =========================================================
       YAHGI PAGE DATA SYNC
       Works now as a standalone page.
       When ready, add a "Capper" column to Results Archive and Active Picks.
       Put "Yahgi" in that column for his plays.
    ========================================================= */

    const SHEET_ID = "15txBM8qsck7f0ZA_za7xYEykBxKpuq0no3x7yHcKNeE";
    const ACTIVE_GID = "0";
    const ARCHIVE_GID = "1579113575";

    const demoPicks = [
      {Date:"May 18, 2025", Sport:"NBA", Game:"Los Angeles Lakers vs Denver Nuggets", Pick:"Los Angeles Lakers -4.5", Odds:"-110", Result:"Pending", Units:"2.0", Capper:"Yahgi", Featured:"Yes"},
      {Date:"May 17, 2025", Sport:"NBA", Game:"Dallas Mavericks", Pick:"Mavericks ML", Odds:"+105", Result:"Win", Units:"2.1", Capper:"Yahgi"},
      {Date:"May 17, 2025", Sport:"NHL", Game:"HOU vs SEA", Pick:"Over 8.5", Odds:"-110", Result:"Win", Units:"2.0", Capper:"Yahgi"},
      {Date:"May 16, 2025", Sport:"NBA", Game:"Miami Heat vs Philadelphia 76ers", Pick:"Miami Heat +3.5", Odds:"-110", Result:"Win", Units:"1.91", Capper:"Yahgi"},
      {Date:"May 16, 2025", Sport:"MLB", Game:"NY Yankees vs BOS", Pick:"NY Yankees -1.5", Odds:"-115", Result:"Win", Units:"1.74", Capper:"Yahgi"}
    ];

    function csvUrl(gid){
      return `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${gid}&cache=${Date.now()}`;
    }

    function parseCSV(text){
      const rows=[]; let row=[],cur="",q=false;
      for(let i=0;i<text.length;i++){
        const c=text[i],n=text[i+1];
        if(c==='"'&&q&&n==='"'){cur+='"';i++;}
        else if(c==='"'){q=!q;}
        else if(c===','&&!q){row.push(cur);cur="";}
        else if((c==='\n'||c==='\r')&&!q){
          if(cur!==""||row.length){row.push(cur);rows.push(row);row=[];cur="";}
          if(c==='\r'&&n==='\n')i++;
        } else cur+=c;
      }
      if(cur!==""||row.length){row.push(cur);rows.push(row);}
      return rows;
    }

    function makeObjects(rows){
      if(!rows.length) return [];
      const headers=rows[0].map(h=>String(h||"").trim());
      return rows.slice(1).map(r=>Object.fromEntries(headers.map((h,i)=>[h,String(r[i]||"").trim()])));
    }

    async function getRows(gid){
      const res = await fetch(csvUrl(gid), {cache:"no-store"});
      if(!res.ok) throw new Error("Sheet did not respond");
      const text = await res.text();
      if(text.toLowerCase().includes("<html")) throw new Error("Sheet returned HTML instead of CSV");
      return makeObjects(parseCSV(text));
    }

    function isYahgi(row){
      const capper = String(row.Capper || row.Handicapper || row.Access || "").toLowerCase();
      const notes = JSON.stringify(row).toLowerCase();
      return capper.includes("yahgi") || notes.includes("yahgi");
    }

    function num(v){
      const n = parseFloat(String(v||"").replace(/[^0-9.+-]/g,""));
      return Number.isFinite(n) ? n : 0;
    }

    function unitsText(v){
      const n=num(v);
      if(!n) return "0.0u";
      return (n>0?"+":"") + n.toFixed(n%1?2:1).replace(/\.00$/,"") + "u";
    }

    function esc(s){
      return String(s||"").replace(/[&<>"]/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;"}[m]));
    }

    function resultClass(r){
      r=String(r||"").toLowerCase();
      if(r.includes("win")) return "win";
      if(r.includes("loss")) return "loss";
      return "pending";
    }

    function currentWinStreak(rows){
      let streak=0;
      const graded=rows.filter(r=>/win|loss/i.test(r.Result||""));
      for(let i=graded.length-1;i>=0;i--){
        if(/win/i.test(graded[i].Result||"")) streak++;
        else break;
      }
      return streak;
    }

    function render(rows){
      const graded = rows.filter(r=>/win|loss/i.test(r.Result||""));
      const wins = graded.filter(r=>/win/i.test(r.Result||"")).length;
      const losses = graded.filter(r=>/loss/i.test(r.Result||"")).length;
      const units = graded.reduce((sum,r)=>sum+num(r["Profit/Loss"]||r.Units),0);
      const winRate = wins+losses ? Math.round((wins/(wins+losses))*100) : 0;
      const streak = currentWinStreak(rows);

      document.getElementById("guruUnits").textContent = unitsText(units);
      document.getElementById("guruWinRate").textContent = winRate + "%";
      document.getElementById("guruRecord").textContent = wins + "-" + losses;
      document.getElementById("guruStreak").textContent = streak;
      document.getElementById("ringUnits").textContent = unitsText(units);
      document.getElementById("ringRate").textContent = winRate + "%";
      document.getElementById("ringRecord").textContent = wins + "-" + losses;
      document.getElementById("streakBig").textContent = streak;
      document.getElementById("flames").textContent = streak ? "🔥".repeat(Math.min(streak,8)) : "🔥🔥🔥";

      const featured = rows.find(r=>/yes/i.test(r.Featured||"")) || rows.find(r=>/pending|pregame|active/i.test((r.Result||"")+(r.Status||""))) || rows[0];
      if(featured){
        document.getElementById("featuredPick").textContent = featured.Pick || "Yahgi Featured Play";
        document.getElementById("featuredGame").textContent = featured.Game || "Independent Guru Release";
        document.getElementById("featuredSport").textContent = featured.Sport || featured.League || "Sport";
        document.getElementById("featuredTime").textContent = featured["Posted Time"] || featured.Date || "Release Time";
        document.getElementById("featuredOdds").textContent = featured.Odds || featured.Line || "Odds";
        document.getElementById("featuredUnits").textContent = (featured.Units || "1") + "u";
      }

      const recentWins = rows.filter(r=>/win/i.test(r.Result||"")).slice(-5).reverse();
      document.getElementById("recentWins").innerHTML = recentWins.length ? recentWins.map(r=>`
        <div class="recent-item">
          <div class="team-badge">${r.Sport==='NBA'?'🏀':r.Sport==='MLB'?'⚾':r.Sport==='NHL'?'🏒':'♛'}</div>
          <div><strong>${esc(r.Pick)}</strong><small>${esc(r.Game||r.Sport||"")}</small></div>
          <span class="win">WIN</span>
        </div>`).join("") : `<div class="recent-item"><div class="team-badge">♛</div><div><strong>No wins yet</strong><small>Waiting on Yahgi archive</small></div><span class="pending">PENDING</span></div>`;

      const latest = rows.slice(-8).reverse();
      document.getElementById("guruTable").innerHTML = latest.length ? latest.map(r=>`
        <tr>
          <td>${esc(r.Date)}</td>
          <td>${esc(r.Sport||r.League)}</td>
          <td>${esc(r.Pick)}</td>
          <td>${esc(r.Odds||r.Line||r["Best Number"])}</td>
          <td class="${resultClass(r.Result)}">${esc(r.Result||r.Status||"Pending")}</td>
          <td class="${resultClass(r.Result)}">${esc(r["Profit/Loss"]||r.Units||"")}</td>
        </tr>`).join("") : `<tr><td colspan="6">No Yahgi picks found yet. Add Capper = Yahgi in your sheet.</td></tr>`;
    }

    async function loadYahgi(){
      try{
        const [active, archive] = await Promise.all([getRows(ACTIVE_GID), getRows(ARCHIVE_GID)]);
        let rows = [...archive, ...active].filter(isYahgi);
        rows = rows.filter(r => (r.Pick || r.Game || r.Result));
        render(rows.length ? rows : demoPicks);
      }catch(err){
        console.warn(err);
        render(demoPicks);
      }
    }

    document.addEventListener("DOMContentLoaded", loadYahgi);
    setInterval(loadYahgi, 30000);
  </script>
</body>
